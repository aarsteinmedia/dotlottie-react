{
  "name": "@aarsteinmedia/dotlottie-react",
  "version": "1.1.13",
  "description": "React component for playing Lottie animations in your React web app.",
  "type": "module",
  "main": "./dist/full.js",
  "types": "./dist/full.d.ts",
  "exports": {
    ".": {
      "types": "./dist/full.d.ts",
      "import": "./dist/full.js",
      "default": "./dist/full.js"
    },
    "./light": {
      "types": "./dist/light.d.ts",
      "import": "./dist/light.js",
      "default": "./dist/light.js"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "import": "./dist/enums.js",
      "default": "./dist/enums.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "repository": {
    "url": "git+https://github.com/aarsteinmedia/dotlottie-react.git",
    "type": "git"
  },
  "bugs": "https://github.com/aarsteinmedia/dotlottie-react/issues",
  "author": {
    "name": "Johan Martin Aarstein",
    "email": "johan@aarstein.media",
    "url": "https://www.aarstein.media",
    "organization": "Aarstein Media"
  },
  "license": "GPL-2.0-or-later",
  "scripts": {
    "dev": "BROWSER='firefox' vite --open",
    "build": "tsc --p ./tsconfig.build.json && vite build",
    "lint": "eslint lib",
    "lint:fix": "eslint lib --fix",
    "lint:css": "npx stylelint lib/**/*.css",
    "lint:css:fix": "npx stylelint lib/**/*.css --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aarsteinmedia/lottie-web": "^1.5.0"
  },
  "peerDependencies": {
    "react": "^19.x",
    "react-dom": "^19.x"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/postcss-flexbugs-fixes": "^5.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-sheriff": "^31.4.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "postcss-flexbugs-fixes": "^5.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup-preserve-directives": "^1.1.3",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended": "^18.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  },
  "sideEffects": [
    "**/*.css",
    "dist/full.js",
    "dist/light.js"
  ],
  "engines": {
    "node": ">= 14.20.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "lottie",
    "dotlottie",
    "bodymovin",
    "react",
    "player"
  ],
  "publishConfig": {
    "access": "public"
  },
  "browserslist": {
    "production": [
      ">0.3%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "funding": {
    "type": "paypal",
    "url": "https://www.paypal.com/donate/?hosted_button_id=E7C7DMN8KSQ6A"
  }
}