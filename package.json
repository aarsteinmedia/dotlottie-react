    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.3",
    "eslint-config-sheriff": "^31.3.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "postcss-flexbugs-fixes": "^5.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-preserve-directives": "^1.1.3",
    "stylelint": "^17.4.0",
